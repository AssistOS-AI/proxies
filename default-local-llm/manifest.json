{
  "container": "docker.io/assistos/default-local-llm:cpu-qwen25-coder-1.5b",
  "agent": "bash /code/startup.sh",
  "about": "Default local LLM — Qwen2.5-Coder-1.5B-Instruct via llama.cpp llama-server",
  "endpoints": {
    "chatCompletions": { "command": "node", "args": ["/code/chat-completions.mjs"], "supportsStream": true }
  },
  "health": {
    "readiness": { "script": "healthcheck.sh", "interval": 5, "timeout": 10, "failureThreshold": 60 }
  },
  "profiles": {
    "default": {
      "env": {
        "LLAMA_MODEL_PATH": { "default": "/opt/models/Qwen2.5-Coder-1.5B-Instruct-Q4_K_M.gguf" },
        "LLAMA_SERVER_PORT": { "default": "8080" },
        "LLAMA_SERVER_BIN": { "default": "llama-server" },
        "LLAMA_CTX_SIZE": { "default": "4096" },
        "LLAMA_THREADS": { "required": false, "default": "" }
      }
    }
  }
}
