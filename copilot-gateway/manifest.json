{
    "container": "oven/bun:latest",
    "agent": "bash /code/startup.sh",
    "cli": "bash /code/cli.sh",
    "about": "GitHub Copilot API Proxy - OpenAI/Anthropic-compatible API using your GitHub Copilot subscription",
    "profiles": {
        "default": {
            "env": {
                "PORT": {
                    "required": false,
                    "default": "4141"
                },
                "COPILOT_ACCOUNT_TYPE": {
                    "required": false,
                    "default": "individual",
                    "description": "Account type: individual, business, or enterprise"
                },
                "COPILOT_VERBOSE": {
                    "required": false,
                    "default": "false",
                    "description": "Enable verbose logging"
                }
            },
            "ports": [
                "4141:4141"
            ],
            "install": "bash /code/install.sh"
        }
    }
}
