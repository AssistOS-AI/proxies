#!/bin/bash
# Deployment Environment Configuration
# Copy this file to setEnv.sh and fill in your values
# DO NOT commit setEnv.sh to version control!

# Remote Server Configuration
export REMOTE_HOST="45.136.70.141"
export REMOTE_USER="admin"
export SSH_KEY_PATH="$HOME/proxies_private_key.pem"

# Domain Configuration
export KIRO_DOMAIN="kiro.axiologic.dev"
export ANTIGRAVITY_DOMAIN="antigravity.axiologic.dev"

# The runtime-v5 deploy helper is intentionally disabled. Do not put proxy API
# keys, agent target ports, or deployment credentials in this file. It remains
# usable only by the separate interactive OAuth authentication helper after an
# operator has provisioned a reviewed runtime-v5 deployment.

# Optional: process-local OAuth callback ports used by auth-gateways.sh.
export KIRO_OAUTH_PORT="51120"
export ANTIGRAVITY_OAUTH_PORT="51121"
