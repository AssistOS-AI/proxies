{
    "container": "node:20-slim",
    "agent": "bash /code/startup.sh",
    "cli": "bash /code/cli.sh",
    "about": "Search Gateway — Web search providers as OpenAI-compatible models",
    "enable": [
        "postgres"
    ],
    "profiles": {
        "default": {
            "env": {
                "PORT": { "required": false, "default": "8043" },
                "PGHOST": { "required": false, "default": "host.containers.internal" },
                "PGPORT": { "required": false, "default": "5432" },
                "PGUSER": { "required": false, "default": "postgres" },
                "PGPASSWORD": { "required": false, "default": "postgres" },
                "PGDATABASE": { "required": false, "default": "postgres" },
                "ENCRYPTION_KEY": { "required": false, "default": "", "description": "AES-256 key for API key encryption (auto-generated if empty)" },
                "DASHBOARD_PASSWORD": { "required": false, "default": "", "description": "Password for dashboard access (empty = no auth)" },
                "SOUL_GATEWAY_API_KEY": { "required": false, "default": "", "description": "For deep-research LLM calls" },
                "SOUL_GATEWAY_URL": { "required": false, "default": "http://10.0.2.2:8042/v1/chat/completions", "description": "Soul Gateway URL for deep-research" }
            },
            "ports": ["0.0.0.0:8043:8043"],
            "install": "bash /code/install.sh"
        }
    }
}
