{
    "container": "node:20-slim",
    "agent": "bash /code/startup.sh",
    "cli": "bash /code/cli.sh",
    "about": "Soul Gateway — LLM proxy with Soul Family policies, full content logging, and operations dashboard",
    "enable": [
        "postgres"
    ],
    "profiles": {
        "default": {
            "env": {
                "PORT": {
                    "required": false,
                    "default": "8042"
                },
                "UPSTREAM_URL": {
                    "required": false,
                    "default": "https://proxy.axiologic.dev",
                    "description": "CLIProxyAPI upstream URL"
                },
                "PGHOST": {
                    "required": false,
                    "default": "host.containers.internal"
                },
                "PGPORT": {
                    "required": false,
                    "default": "5432"
                },
                "PGUSER": {
                    "required": false,
                    "default": "postgres"
                },
                "PGPASSWORD": {
                    "required": false,
                    "default": "postgres"
                },
                "PGDATABASE": {
                    "required": false,
                    "default": "postgres"
                },
                "ENCRYPTION_KEY": {
                    "required": false,
                    "default": "",
                    "description": "AES-256 key for API key encryption (auto-generated if empty)"
                },
                "WORKSPACE_PATH": {
                    "required": false,
                    "default": ""
                },
                "DEFAULT_PROXY_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for authenticating with cliproxyapi upstream"
                },
                "DASHBOARD_PASSWORD": {
                    "required": false,
                    "default": "",
                    "description": "Password for dashboard access (empty = no auth)"
                },
                "AXIOLOGIC_PROXY_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for axiologic proxy (CLIProxyAPI)"
                },
                "OPENROUTER_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for OpenRouter"
                },
                "COPILOT_API_KEY": {
                    "required": false,
                    "default": "no-auth-needed",
                    "description": "Dummy key for copilot provider (copilot-gateway handles its own auth)"
                },
                "KIRO_PROXY_API_KEY": {
                    "required": false,
                    "default": "no-auth-needed",
                    "description": "Dummy key for kiro provider (kiro-gateway handles its own auth)"
                }
            },
            "ports": [
                "0.0.0.0:8042:8042"
            ],
            "install": "bash /code/install.sh"
        }
    }
}
