{
    "container": "docker.io/assistos/ploinky-node:24-bookworm-tools",
    "agent": "bash /code/startup.sh",
    "cli": "bash /code/cli.sh",
    "about": "Soul Gateway — Ploinky-managed LLM proxy with Soul Family policies, full content logging, and AchillesIDE settings",
    "enable": ["postgres"],
    "readiness": {
        "protocol": "tcp"
    },
    "httpServices": [
        {
            "externalPrefix": "/services/soul-gateway/v1/",
            "internalPrefix": "/v1/",
            "auth": "none"
        },
        {
            "externalPrefix": "/services/soul-gateway/management/",
            "internalPrefix": "/management/",
            "auth": "protected"
        },
        {
            "externalPrefix": "/public-services/soul-gateway-health/",
            "internalPrefix": "/healthz/",
            "auth": "none"
        }
    ],
    "ideSettings": [
        {
            "key": "soul-gateway",
            "label": "Soul Gateway",
            "scope": "workspace",
            "pluginKey": "soul-gateway/soul-gateway",
            "settingsUrl": "/services/soul-gateway/management/",
            "adminOnly": true
        }
    ],
    "profiles": {
        "default": {
            "env": {
                "PORT": {
                    "required": false,
                    "default": "7000"
                },
                "UPSTREAM_URL": {
                    "required": false,
                    "default": "https://proxy.axiologic.dev",
                    "description": "CLIProxyAPI upstream URL"
                },
                "PGHOST": {
                    "required": false,
                    "default": "host.containers.internal"
                },
                "PGPORT": {
                    "required": false,
                    "default": "5432"
                },
                "PGUSER": {
                    "required": false,
                    "default": "postgres"
                },
                "PGPASSWORD": {
                    "required": false,
                    "default": "postgres"
                },
                "PGDATABASE": {
                    "required": false,
                    "default": "postgres"
                },
                "ENCRYPTION_KEY": {
                    "required": false,
                    "default": "",
                    "description": "AES-256 key for API key encryption (auto-generated if empty)"
                },
                "WORKSPACE_PATH": {
                    "required": false,
                    "default": ""
                },
                "DEFAULT_PROXY_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for authenticating with cliproxyapi upstream"
                },
                "SOUL_GATEWAY_API_KEY": {
                    "required": true,
                    "sharedGeneratedSecret": true,
                    "description": "Managed workspace API key accepted by /v1/*"
                },
                "SOUL_GATEWAY_PROVIDER_API_KEY": {
                    "varName": "SOUL_GATEWAY_API_KEY",
                    "required": false,
                    "default": "",
                    "description": "Optional API key for bootstrapping the remote Soul Gateway as a normal provider; sourced from operator SOUL_GATEWAY_API_KEY while the local SOUL_GATEWAY_API_KEY remains generated"
                },
                "SOUL_GATEWAY_PROVIDER_BASE_URL": {
                    "required": false,
                    "default": "https://soul.axiologic.dev/v1",
                    "description": "OpenAI-compatible base URL for the remote Soul Gateway provider"
                },
                "SOUL_GATEWAY_PROVIDER_DISCOVERY_MODE": {
                    "required": false,
                    "default": "auto",
                    "description": "Use auto to sync the remote Soul Gateway /models at startup, or off to create only the provider/account"
                },
                "SOUL_GATEWAY_PROVIDER_ALIASES": {
                    "required": false,
                    "default": "fast,axl/fast,plan,code,write,deep,ultra",
                    "description": "Comma-separated aliases mirrored to same-named remote Soul Gateway provider models when discovered"
                },
                "ALLOW_UNAUTHENTICATED": {
                    "required": false,
                    "default": "false",
                    "description": "Development-only switch that disables /v1/* API key auth"
                },
                "LOCAL_LLM_BASE_URL": {
                    "required": false,
                    "default": "",
                    "description": "OpenAI-compatible endpoint for explicitly enabled local LLM bootstrap"
                },
                "LOCAL_LLM_MODEL": {
                    "required": false,
                    "default": ""
                },
                "LOCAL_LLM_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "Optional bearer token or API key for the local LLM endpoint"
                },
                "LOCAL_LLM_DISCOVERY_MODE": {
                    "required": false,
                    "default": "single",
                    "description": "Use single to register only LOCAL_LLM_MODEL, or auto to probe the endpoint model list"
                },
                "LOCAL_LLM_ALIASES": {
                    "required": false,
                    "default": "fast,axl/fast,plan,code,write,deep,ultra",
                    "description": "Comma-separated aliases mapped to LOCAL_LLM_MODEL for legacy agent defaults"
                },
                "AXIOLOGIC_PROXY_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for axiologic proxy (CLIProxyAPI)"
                },
                "OPENROUTER_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for OpenRouter"
                },
                "COPILOT_API_KEY": {
                    "required": false,
                    "default": "no-auth-needed",
                    "description": "Dummy key for copilot provider (copilot-gateway handles its own auth)"
                },
                "KIRO_PROXY_API_KEY": {
                    "required": false,
                    "default": "no-auth-needed",
                    "description": "Dummy key for kiro provider (kiro-gateway handles its own auth)"
                },
                "TAVILY_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Tavily web search"
                },
                "BRAVE_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Brave web search"
                },
                "EXA_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Exa web search"
                },
                "SERPER_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Serper (Google) web search"
                },
                "JINA_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Jina web search (optional)"
                },
                "BROWSER_POOL_SIZE": {
                    "required": false,
                    "default": "0",
                    "description": "Number of Chromium browser instances for headless search"
                },
                "BROWSER_EXECUTABLE_PATH": {
                    "required": false,
                    "default": "",
                    "description": "Path to Chrome/Chromium inside the container"
                },
                "BROWSER_HEADLESS_MODE": {
                    "required": false,
                    "default": "new",
                    "description": "Puppeteer headless mode for browser search"
                },
                "BROWSER_PROXY_URL": {
                    "required": false,
                    "default": "",
                    "description": "Optional proxy server for browser search"
                },
                "BROWSER_USER_DATA_DIR": {
                    "required": false,
                    "default": "",
                    "description": "Optional persistent Chromium user data directory"
                },
                "OAUTH_ADAPTERS_ENABLED": {
                    "required": false,
                    "default": "",
                    "description": "Comma-separated OAuth adapters to enable"
                },
                "TOKEN_REFRESH_INTERVAL_MS": {
                    "required": false,
                    "default": "0",
                    "description": "Set a positive interval to enable token refresh scheduling"
                },
                "PRICING_REFRESH_INTERVAL_MS": {
                    "required": false,
                    "default": "0",
                    "description": "Set a positive interval to enable pricing refresh scheduling"
                }
            },
            "ports": [],
            "install": "bash /code/install.sh"
        }
    }
}
