{
    "container": "node:20-slim",
    "agent": "bash /code/startup-v2.sh",
    "cli": "bash /code/cli.sh",
    "about": "Soul Gateway — LLM proxy with Soul Family policies, full content logging, and operations dashboard",
    "enable": ["postgres"],
    "readiness": {
        "protocol": "tcp"
    },
    "httpServices": [
        {
            "externalPrefix": "/services/soul-gateway/v1/",
            "internalPrefix": "/v1/",
            "auth": "none"
        },
        {
            "externalPrefix": "/services/soul-gateway/management/",
            "internalPrefix": "/management/",
            "auth": "protected"
        },
        {
            "externalPrefix": "/public-services/soul-gateway-health/",
            "internalPrefix": "/healthz/",
            "auth": "none"
        }
    ],
    "profiles": {
        "default": {
            "env": {
                "PORT": {
                    "required": false,
                    "default": "8042"
                },
                "UPSTREAM_URL": {
                    "required": false,
                    "default": "https://proxy.axiologic.dev",
                    "description": "CLIProxyAPI upstream URL"
                },
                "PGHOST": {
                    "required": false,
                    "default": "host.containers.internal"
                },
                "PGPORT": {
                    "required": false,
                    "default": "5432"
                },
                "PGUSER": {
                    "required": false,
                    "default": "postgres"
                },
                "PGPASSWORD": {
                    "required": false,
                    "default": "postgres"
                },
                "PGDATABASE": {
                    "required": false,
                    "default": "postgres"
                },
                "ENCRYPTION_KEY": {
                    "required": false,
                    "default": "",
                    "description": "AES-256 key for API key encryption (auto-generated if empty)"
                },
                "WORKSPACE_PATH": {
                    "required": false,
                    "default": ""
                },
                "DEFAULT_PROXY_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for authenticating with cliproxyapi upstream"
                },
                "DASHBOARD_PASSWORD": {
                    "required": false,
                    "default": "",
                    "description": "Password for dashboard access (empty = no auth)"
                },
                "AXIOLOGIC_PROXY_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for axiologic proxy (CLIProxyAPI)"
                },
                "OPENROUTER_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for OpenRouter"
                },
                "COPILOT_API_KEY": {
                    "required": false,
                    "default": "no-auth-needed",
                    "description": "Dummy key for copilot provider (copilot-gateway handles its own auth)"
                },
                "KIRO_PROXY_API_KEY": {
                    "required": false,
                    "default": "no-auth-needed",
                    "description": "Dummy key for kiro provider (kiro-gateway handles its own auth)"
                },
                "TAVILY_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Tavily web search"
                },
                "BRAVE_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Brave web search"
                },
                "EXA_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Exa web search"
                },
                "SERPER_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Serper (Google) web search"
                },
                "JINA_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Jina web search (optional)"
                },
                "BROWSER_POOL_SIZE": {
                    "required": false,
                    "default": "0",
                    "description": "Number of Chromium browser instances for headless search"
                },
                "BROWSER_EXECUTABLE_PATH": {
                    "required": false,
                    "default": "",
                    "description": "Path to Chrome/Chromium inside the container"
                },
                "BROWSER_HEADLESS_MODE": {
                    "required": false,
                    "default": "new",
                    "description": "Puppeteer headless mode for browser search"
                },
                "BROWSER_PROXY_URL": {
                    "required": false,
                    "default": "",
                    "description": "Optional proxy server for browser search"
                },
                "BROWSER_USER_DATA_DIR": {
                    "required": false,
                    "default": "",
                    "description": "Optional persistent Chromium user data directory"
                }
            },
            "ports": ["0.0.0.0:8042:8042"],
            "install": "bash /code/install-v2.sh"
        },
        "standalone": {
            "ports": ["0.0.0.0:8042:8042"]
        },
        "embedded": {
            "ports": [],
            "env": [
                {
                    "name": "PORT",
                    "required": false,
                    "default": "7000"
                },
                {
                    "name": "SOUL_GATEWAY_MODE",
                    "required": false,
                    "default": "embedded"
                },
                {
                    "name": "TRUST_PLOINKY_ROUTER_AUTH",
                    "required": false,
                    "default": "true"
                },
                {
                    "name": "ALLOW_UNAUTHENTICATED",
                    "required": false,
                    "default": "false"
                },
                {
                    "name": "LOCAL_LLM_BASE_URL",
                    "required": false,
                    "default": "https://lmstudio.axiologic.dev/v1",
                    "description": "Default OpenAI-compatible endpoint for the embedded local LLM deployment"
                },
                {
                    "name": "LOCAL_LLM_MODEL",
                    "required": false,
                    "default": "gemma-3-12b-it"
                },
                {
                    "name": "LOCAL_LLM_API_KEY",
                    "required": false,
                    "description": "Optional bearer token or API key for the embedded local LLM endpoint"
                },
                {
                    "name": "LOCAL_LLM_DISCOVERY_MODE",
                    "required": false,
                    "default": "single",
                    "description": "Use single to register only LOCAL_LLM_MODEL, or auto to probe the endpoint model list"
                },
                {
                    "name": "LOCAL_LLM_ALIASES",
                    "required": false,
                    "default": "fast,axl/fast,plan,code,write,deep,ultra",
                    "description": "Comma-separated aliases mapped to the embedded local LLM model for legacy agent defaults"
                },
                {
                    "name": "ENCRYPTION_KEY",
                    "required": true,
                    "derive": "derived-master",
                    "deriveName": "soul-gateway-encryption-key"
                },
                {
                    "name": "ADMIN_SESSION_SIGNING_KEY",
                    "required": true,
                    "derive": "derived-master",
                    "deriveName": "soul-gateway-admin-session"
                },
                {
                    "name": "SOUL_GATEWAY_API_KEY",
                    "required": true,
                    "derive": "derived-master",
                    "deriveName": "workspace-default-api-key"
                },
                {
                    "name": "DASHBOARD_PASSWORD",
                    "required": false,
                    "default": ""
                },
                {
                    "name": "OAUTH_ADAPTERS_ENABLED",
                    "required": false,
                    "default": ""
                },
                {
                    "name": "TOKEN_REFRESH_INTERVAL_MS",
                    "required": false,
                    "default": "0"
                },
                {
                    "name": "PRICING_REFRESH_INTERVAL_MS",
                    "required": false,
                    "default": "0"
                }
            ],
            "install": "bash /code/install-v2.sh"
        }
    }
}
