{
    "container": "docker.io/assistos/ploinky-node:24-bookworm-tools",
    "agent": "bash /code/startup.sh",
    "cli": "bash /code/cli.sh",
    "about": "Soul Gateway — Ploinky-managed LLM proxy with Soul Family policies, full content logging, and AchillesIDE settings",
    "volumes": {
        ".ploinky/data/soul-gateway": "/data"
    },
    "readiness": {
        "protocol": "tcp"
    },
    "httpServices": [
        {
            "externalPrefix": "/services/soul-gateway/v1/",
            "internalPrefix": "/v1/",
            "access": "guest"
        },
        {
            "externalPrefix": "/services/soul-gateway/management/",
            "internalPrefix": "/management/",
            "access": "authenticated"
        },
        {
            "externalPrefix": "/public-services/soul-gateway-health/",
            "internalPrefix": "/healthz/",
            "access": "public"
        }
    ],
    "ideSettings": [
        {
            "key": "soul-gateway",
            "label": "Soul Gateway",
            "scope": "workspace",
            "pluginKey": "soul-gateway/soul-gateway",
            "settingsUrl": "/services/soul-gateway/management/",
            "adminOnly": true
        }
    ],
    "enable": [
        "default-local-llm no-wait"
    ],
    "profiles": {
        "default": {
            "env": {
                "PORT": {
                    "required": false,
                    "default": "7000"
                },
                "UPSTREAM_URL": {
                    "required": false,
                    "default": "https://proxy.axiologic.dev",
                    "description": "CLIProxyAPI upstream URL"
                },
                "SQLITE_PATH": {
                    "required": false,
                    "default": "/data/soul-gateway.sqlite3",
                    "description": "SQLite database path inside the Soul Gateway agent container"
                },
                "ENCRYPTION_KEY": {
                    "required": false,
                    "default": "",
                    "description": "AES-256 key for API key encryption (auto-generated if empty)"
                },
                "WORKSPACE_PATH": {
                    "required": false,
                    "default": ""
                },
                "DEFAULT_PROXY_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for authenticating with cliproxyapi upstream"
                },
                "ALLOW_UNAUTHENTICATED": {
                    "required": false,
                    "default": "false",
                    "description": "Development-only switch that disables /v1/* API key auth"
                },
                "LLM_DEFAULT_AGENT": {
                    "required": false,
                    "default": "default-local-llm",
                    "description": "Local Ploinky agent whose discovered model seeds the basic tiers"
                },
                "LLM_DEFAULT_TIERS": {
                    "required": false,
                    "default": "fast,plan,deep",
                    "description": "Comma-separated tier aliases seeded to LLM_DEFAULT_AGENT's model"
                },
                "AXL_PROXY_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for an upstream AXL Proxy (remote soul-gateway). When set, the local gateway mirrors the upstream /v1/models catalog as a delegating 'axl-proxy' provider. Resolved from .secrets, process.env, or the nearest ancestor .env."
                },
                "AXL_PROXY_BASE_URL": {
                    "required": false,
                    "default": "",
                    "description": "Base URL of the upstream AXL Proxy OpenAI-compatible API (e.g. https://soul.axiologic.dev/v1). Required for the mirror to activate."
                },
                "AXL_PROXY_DISCOVERY_MODE": {
                    "required": false,
                    "default": "auto",
                    "description": "auto = sync the upstream /v1/models at startup; off = register the provider/account only."
                },
                "AXIOLOGIC_PROXY_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for axiologic proxy (CLIProxyAPI)"
                },
                "OPENROUTER_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for OpenRouter"
                },
                "COPILOT_API_KEY": {
                    "required": false,
                    "default": "no-auth-needed",
                    "description": "Dummy key for copilot provider (copilot-gateway handles its own auth)"
                },
                "KIRO_PROXY_API_KEY": {
                    "required": false,
                    "default": "no-auth-needed",
                    "description": "Dummy key for kiro provider (kiro-gateway handles its own auth)"
                },
                "TAVILY_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Tavily web search"
                },
                "BRAVE_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Brave web search"
                },
                "EXA_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Exa web search"
                },
                "SERPER_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Serper (Google) web search"
                },
                "JINA_API_KEY": {
                    "required": false,
                    "default": "",
                    "description": "API key for Jina web search (optional)"
                },
                "BROWSER_POOL_SIZE": {
                    "required": false,
                    "default": "0",
                    "description": "Number of Chromium browser instances for headless search"
                },
                "BROWSER_EXECUTABLE_PATH": {
                    "required": false,
                    "default": "",
                    "description": "Path to Chrome/Chromium inside the container"
                },
                "BROWSER_HEADLESS_MODE": {
                    "required": false,
                    "default": "new",
                    "description": "Puppeteer headless mode for browser search"
                },
                "BROWSER_PROXY_URL": {
                    "required": false,
                    "default": "",
                    "description": "Optional proxy server for browser search"
                },
                "BROWSER_USER_DATA_DIR": {
                    "required": false,
                    "default": "",
                    "description": "Optional persistent Chromium user data directory"
                },
                "OAUTH_ADAPTERS_ENABLED": {
                    "required": false,
                    "default": "",
                    "description": "Comma-separated OAuth adapters to enable"
                },
                "TOKEN_REFRESH_INTERVAL_MS": {
                    "required": false,
                    "default": "0",
                    "description": "Set a positive interval to enable token refresh scheduling"
                },
                "PRICING_REFRESH_INTERVAL_MS": {
                    "required": false,
                    "default": "0",
                    "description": "Set a positive interval to enable pricing refresh scheduling"
                }
            },
            "ports": [],
            "install": "bash /code/install.sh"
        }
    }
}
